# Supabase — get these from Project Settings → API in the Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Direct PostgreSQL connection string for schema auto-initialization on deploy.
# Find it in: Supabase dashboard → Project Settings → Database → Connection string → URI
# Used by scripts/setup-db.mjs (postbuild) to create tables if they don't exist.
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Set SEED_DB=true on the FIRST deployment to also insert sample data (lockers, couriers, tariffs).
# Remove or set to false afterwards to avoid duplicate data.
SEED_DB=false

# JWT secret — use the Supabase JWT secret from Project Settings → API → JWT Settings
SECRET_KEY=your-jwt-secret

# Admin credentials
# ADMIN_LOGIN / ADMIN_PASSWORD are used by `npm run create-admin` to create/update the admin user.
# NEXT_PUBLIC_ADMIN_LOGIN / NEXT_PUBLIC_ADMIN_PASSWORD are optional dev-only helpers: when both are set
# they pre-fill the "⚡ Admin Login" quick-fill button on the login page.
# ⚠️  WARNING: NEXT_PUBLIC_* vars are embedded in the client JS bundle and visible to anyone.
# ⚠️  NEVER set NEXT_PUBLIC_ADMIN_LOGIN or NEXT_PUBLIC_ADMIN_PASSWORD in production or any
#     publicly accessible environment. Use them only in local .env.local files for development.
ADMIN_LOGIN=admin
ADMIN_PASSWORD=your-admin-password
# Local dev only — remove/leave blank in production:
NEXT_PUBLIC_ADMIN_LOGIN=admin
NEXT_PUBLIC_ADMIN_PASSWORD=

# Max (VK Teams) bot token
MAX_BOT_TOKEN=your-max-bot-token

# Payment gateway
ACQUIRING_API_KEY=
ACQUIRING_BASE_URL=https://api.acquiring.example.com

# Gosuslugi OAuth (user identity verification)
GOSUSLUGI_CLIENT_ID=
GOSUSLUGI_CLIENT_SECRET=

# Cron job protection secret (set in Vercel → Cron → Advanced)
CRON_SECRET=
