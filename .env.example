# Supabase — get these from Project Settings → API in the Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# When using the Vercel ↔ Supabase integration the vars below are set automatically.
# They are also accepted as aliases for the ones above.
rezaryad_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_rezaryad_SUPABASE_URL=https://your-project-id.supabase.co

# Direct PostgreSQL connection strings for schema auto-initialization on deploy.
# These are set automatically by the Vercel ↔ Supabase integration.
# scripts/setup-db.mjs prefers rezaryad_POSTGRES_URL_NON_POOLING (required for DDL —
# the pooler uses PgBouncer which does not support multi-statement DDL queries).
rezaryad_POSTGRES_URL_NON_POOLING=postgres://postgres.[project-ref]:[password]@aws-1-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require
rezaryad_POSTGRES_URL=postgres://postgres.[project-ref]:[password]@aws-1-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require
# Generic fallback (only needed if you are not using the Vercel ↔ Supabase integration):
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Set SEED_DB=true to force re-insert of sample data on an already-initialised DB.
# On first deploy seeding is automatic — no flag needed.
SEED_DB=false

# JWT secret — use the Supabase JWT secret from Project Settings → API → JWT Settings
SECRET_KEY=your-jwt-secret

# Admin credentials
# ADMIN_LOGIN / ADMIN_PASSWORD are used by `npm run create-admin` to create/update the admin user.
# NEXT_PUBLIC_ADMIN_LOGIN / NEXT_PUBLIC_ADMIN_PASSWORD are optional dev-only helpers: when both are set
# they pre-fill the "⚡ Admin Login" quick-fill button on the login page.
# ⚠️  WARNING: NEXT_PUBLIC_* vars are embedded in the client JS bundle and visible to anyone.
# ⚠️  NEVER set NEXT_PUBLIC_ADMIN_LOGIN or NEXT_PUBLIC_ADMIN_PASSWORD in production or any
#     publicly accessible environment. Use them only in local .env.local files for development.
ADMIN_LOGIN=admin
ADMIN_PASSWORD=your-admin-password
# Local dev only — remove/leave blank in production:
NEXT_PUBLIC_ADMIN_LOGIN=admin
NEXT_PUBLIC_ADMIN_PASSWORD=

# Max (VK Teams) bot token
MAX_BOT_TOKEN=your-max-bot-token

# Payment gateway
ACQUIRING_API_KEY=
ACQUIRING_BASE_URL=https://api.acquiring.example.com

# Gosuslugi OAuth (user identity verification)
GOSUSLUGI_CLIENT_ID=
GOSUSLUGI_CLIENT_SECRET=

# Cron job protection secret (set in Vercel → Cron → Advanced)
CRON_SECRET=

# External locker service integration (battery swap feature)
# URL of the hardware/locker management webservice.
# Used by the swap flow to locate a user's stored battery and open the correct locker.
LOCKER_SERVICE_URL=https://your-locker-service.example.com
