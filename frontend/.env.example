# Backend API URL
# - Leave EMPTY when deploying as a single Vercel project: the Python backend
#   runs at /api/* on the same domain (routed by vercel.json) so no URL is needed.
# - Set to http://localhost:8000 for local development when running the FastAPI
#   backend separately (OR leave empty and use the built-in Next.js dev proxy).
NEXT_PUBLIC_API_URL=http://localhost:8000

# Supabase (optional — only needed if the frontend uses Supabase directly)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# Optional: pre-fill password for the "Admin Login" quick-fill button (dev/testing only)
NEXT_PUBLIC_DEV_ADMIN_PASSWORD=
