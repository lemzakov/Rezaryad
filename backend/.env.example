# ============================================================
# Database
# ============================================================
# Option A – explicit URL (local dev or custom Postgres)
DATABASE_URL=postgresql://user:password@localhost:5432/rezaryad

# Option B – Vercel + Supabase integration (auto-injected)
# When you connect a Supabase database to a Vercel project the
# integration automatically sets these variables.  You do NOT
# need to set DATABASE_URL when these are present — config.py
# resolves them automatically:
#
#   rezaryad_POSTGRES_PRISMA_URL       → DATABASE_URL      (pooled, runtime queries)
#   rezaryad_POSTGRES_URL_NON_POOLING  → DIRECT_DATABASE_URL (direct, schema migrations)
#
# If you prefer to be explicit you can also copy the values here:
# DATABASE_URL=<value of rezaryad_POSTGRES_PRISMA_URL>
# DIRECT_DATABASE_URL=<value of rezaryad_POSTGRES_URL_NON_POOLING>

# ============================================================
# MAX Bot
# ============================================================
MAX_BOT_TOKEN=your_max_bot_token_here

# ============================================================
# JWT
# ============================================================
# Option A – set an explicit secret (recommended in production)
SECRET_KEY=your-very-secret-key-change-in-production
# Option B – Vercel + Supabase: rezaryad_SUPABASE_JWT_SECRET is used
# automatically when SECRET_KEY is absent.

# ============================================================
# Acquiring (payment gateway)
# ============================================================
ACQUIRING_API_KEY=your_acquiring_api_key
ACQUIRING_BASE_URL=https://api.acquiring.example.com

# ============================================================
# Gosuslugi OAuth
# ============================================================
GOSUSLUGI_CLIENT_ID=your_gosuslugi_client_id
GOSUSLUGI_CLIENT_SECRET=your_gosuslugi_client_secret

# ============================================================
# Admin panel
# ============================================================
# Password for the built-in 'admin' account.
# The server auto-creates/updates the account on every startup.
ADMIN_PASSWORD=your_admin_password_here

# ============================================================
# CORS
# ============================================================
# Comma-separated list of allowed origins.
# Leave empty to allow all origins (development only).
CORS_ORIGINS=https://your-frontend.vercel.app,https://admin.yourapp.com
