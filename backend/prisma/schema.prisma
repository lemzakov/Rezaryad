generator client {
  provider             = "python3 -m prisma"
  recursive_type_depth = 5
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // directUrl bypasses PgBouncer and is used by `prisma db push` / migrations.
  // On Supabase this maps to DIRECT_DATABASE_URL (= rezaryad_POSTGRES_URL_NON_POOLING).
  directUrl = env("DIRECT_DATABASE_URL")
}

enum Language {
  RU
  UZ
  TJ
}

enum CellStatus {
  FREE
  BUSY
  BROKEN
}

enum BookingStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  CONVERTED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

model User {
  id               String        @id @default(cuid())
  maxId            String        @unique
  phone            String?
  language         Language      @default(RU)
  isVerified       Boolean       @default(false)
  verificationData Json?
  hasDebt          Boolean       @default(false)
  debtAmount       Float         @default(0)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  cards            PaymentCard[]
  subscriptions    Subscription[]
  bookings         Booking[]
  sessions         Session[]
  payments         Payment[]
  notifications    Notification[]
  waitQueue        WaitQueue[]
}

model PaymentCard {
  id         String   @id @default(cuid())
  userId     String
  cardToken  String
  lastFour   String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id])
}

model Locker {
  id        String    @id @default(cuid())
  name      String
  address   String
  lat       Float
  lon       Float
  qrCode    String    @unique
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())

  cells     Cell[]
  waitQueue WaitQueue[]
}

model Cell {
  id         String     @id @default(cuid())
  lockerId   String
  number     Int
  status     CellStatus @default(FREE)
  hasCharger Boolean    @default(true)
  createdAt  DateTime   @default(now())

  locker     Locker     @relation(fields: [lockerId], references: [id])
  bookings   Booking[]
  sessions   Session[]
}

model Tariff {
  id                 String         @id @default(cuid())
  name               String
  pricePerMinute     Float
  isSubscription     Boolean        @default(false)
  subscriptionPeriod Int?
  freeMins           Int            @default(5)
  discountPct        Float          @default(0)
  isNight            Boolean        @default(false)
  createdAt          DateTime       @default(now())

  subscriptions      Subscription[]
}

model Subscription {
  id        String   @id @default(cuid())
  userId    String
  tariffId  String
  startAt   DateTime @default(now())
  endAt     DateTime
  isActive  Boolean  @default(true)
  autoRenew Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  tariff    Tariff   @relation(fields: [tariffId], references: [id])
}

model Booking {
  id           String        @id @default(cuid())
  userId       String
  cellId       String
  status       BookingStatus @default(ACTIVE)
  isFree       Boolean       @default(true)
  endsAt       DateTime
  penaltyUntil DateTime?
  createdAt    DateTime      @default(now())

  user         User          @relation(fields: [userId], references: [id])
  cell         Cell          @relation(fields: [cellId], references: [id])
  sessions     Session[]
}

model Session {
  id           String    @id @default(cuid())
  userId       String
  cellId       String
  bookingId    String?
  startAt      DateTime  @default(now())
  endAt        DateTime?
  durationMins Float?
  cost         Float?
  isPaid       Boolean   @default(false)
  createdAt    DateTime  @default(now())

  user         User      @relation(fields: [userId], references: [id])
  cell         Cell      @relation(fields: [cellId], references: [id])
  booking      Booking?  @relation(fields: [bookingId], references: [id])
  payments     Payment[]
}

model Payment {
  id        String        @id @default(cuid())
  userId    String
  sessionId String?
  amount    Float
  status    PaymentStatus @default(PENDING)
  cardToken String?
  createdAt DateTime      @default(now())

  user      User          @relation(fields: [userId], references: [id])
  session   Session?      @relation(fields: [sessionId], references: [id])
}

model Notification {
  id      String   @id @default(cuid())
  userId  String
  type    String
  message String
  sentAt  DateTime @default(now())
  isRead  Boolean  @default(false)

  user    User     @relation(fields: [userId], references: [id])
}

model AdminUser {
  id           String   @id @default(cuid())
  login        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model WaitQueue {
  id        String   @id @default(cuid())
  userId    String
  lockerId  String
  position  Int
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  locker    Locker   @relation(fields: [lockerId], references: [id])
}
